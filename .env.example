# Database Configuration
DB_HOST=localhost
DB_NAME=reqon_db
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=Reqon
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/reqon

# Session Configuration
SESSION_LIFETIME=1800
SESSION_NAME=reqon_session

# Email Configuration (for later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@reqon.com
SMTP_FROM_NAME=Reqon System

# Security
HASH_ALGO=bcrypt
ENCRYPTION_KEY=your-random-32-character-key-here

# Pagination
ITEMS_PER_PAGE=20

# File Upload
UPLOAD_MAX_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx